rules_version = '2';
/* ================================================================
   WordQuest Firestore 보안 규칙 (schema 2)
   ----------------------------------------------------------------
   users/{uid}                → 본인 read/write. 선생님은 자기 반 학생만 read.
   users/{uid}/private/state  → 본인만 read/write (무거운 학습 데이터).
   classes/{classId}          → 로그인 사용자 read(코드 조회용), 소유 선생님만 write.
   그 외 전면 거부.
   ================================================================ */
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // 이 문서(학생)의 소속 반을 요청자가 소유(담당 선생님)하는가
    function ownsStudentClass(data) {
      return signedIn()
        && data.classId != null
        && exists(/databases/$(database)/documents/classes/$(data.classId))
        && get(/databases/$(database)/documents/classes/$(data.classId)).data.ownerUid == request.auth.uid;
    }

    // users/{uid} 쓰기 필드 검증 — 있을 때만 타입/크기 확인.
    // 선생님 대시보드가 이 값을 읽어 화면에 그리므로, 위조 문자열이 섞이지 않게 서버단에서 제약(XSS 방어 심층).
    function validUserDoc(d) {
      return (!('displayName' in d) || (d.displayName is string && d.displayName.size() <= 40))
        && (!('className' in d)   || (d.className is string && d.className.size() <= 60))
        && (!('classId' in d)     || (d.classId is string && d.classId.size() <= 64))
        && (!('role' in d)        || (d.role is string && (d.role == 'student' || d.role == 'teacher')))
        && (!('summary' in d)     || d.summary is map)
        && (!('profile' in d)     || d.profile is map);
    }

    match /users/{uid} {
      // 본인은 항상, 선생님은 자기 반 학생 문서를 읽을 수 있다.
      allow read: if signedIn() && (request.auth.uid == uid || ownsStudentClass(resource.data));
      // 쓰기는 본인만 + 필드 타입/크기 검증.
      allow write: if signedIn() && request.auth.uid == uid && validUserDoc(request.resource.data);

      // 무거운 학습 데이터: 본인만.
      match /private/{docId} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }

    match /classes/{classId} {
      // 코드 조회에 필요해 로그인 사용자 read 허용. 단, 규칙만으로는 "코드로 조회"만 허용하고
      // "전체 열거"를 막을 수 없다 → 로그인한 사용자는 반 코드/이름을 모두 조회 가능(약한 관문).
      // 완전 차단은 Cloud Function(코드 검증 서버화)이 필요. 반 코드에 민감정보를 담지 말 것.
      allow read: if signedIn();
      // 생성: 로그인 사용자가 자신을 소유자로.
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      // 수정·삭제: 소유 선생님만.
      allow update, delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
