rules_version = '2';
/* ================================================================
   WordQuest Firestore 보안 규칙 (schema 2)
   ----------------------------------------------------------------
   users/{uid}                → 본인 read/write. 선생님은 자기 반 학생만 read.
   users/{uid}/private/state  → 본인만 read/write (무거운 학습 데이터).
   classes/{classId}          → 소유 선생님만 read/write(수정 시 코드·소유자 불변).
   classCodes/{code}          → 코드→반 매핑. 단건 get 만(열거 불가), 생성 전용(코드 유일성).
   그 외 전면 거부.

   ★ 선생님 권한(2026-07-15)
     선생님으로의 승격은 "위조 불가능한 커스텀 클레임"(request.auth.token.teacher)으로만
     인정한다. 이 클레임은 Cloudflare Worker(teacher-worker)가 비밀번호(TEACHER_PW)를
     확인한 뒤 Firebase Admin 으로만 부여할 수 있다. 따라서 학생이 클라이언트/콘솔에서
     role='teacher' 를 스스로 쓰거나 반을 만드는 시도는 서버에서 전부 거부된다.
     (과거: 클라이언트 하드코딩 비밀번호 = 소프트 게이트 → 소스 열람/콘솔로 우회 가능했음.)
   ================================================================ */
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // 마스터(운영자): 지정 이메일 계정은 모든 학생·반을 읽을 수 있다(전체 열람 전용).
    // ★ cloud.js 의 MASTER_EMAIL 과 반드시 동일하게 유지. 쓰기 권한은 부여하지 않음.
    function isMaster() {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'ranha.park@gmail.com';
    }

    // 선생님: teacher-worker 가 비밀번호 확인 후 부여한 커스텀 클레임만 인정(위조 불가).
    //   클라이언트가 스스로 만들 수 없으므로, 학생의 임의 승격을 서버에서 원천 차단한다.
    function isTeacher() {
      return signedIn() && request.auth.token.teacher == true;
    }
    // 선생님 권한이 필요한 쓰기(역할·반·배포)에 쓰는 게이트. 마스터는 항상 허용(운영자 잠금 방지).
    function teacherAllowed() { return isTeacher() || isMaster(); }

    // 이 문서(학생)의 소속 반을 요청자가 소유(담당 선생님)하는가
    function ownsStudentClass(data) {
      return signedIn()
        && data.classId != null
        && exists(/databases/$(database)/documents/classes/$(data.classId))
        && get(/databases/$(database)/documents/classes/$(data.classId)).data.ownerUid == request.auth.uid;
    }

    // 요청자(로그인 사용자)가 속한 반 id (없으면 null) — 반 랭킹 접근 판정용
    function requesterClassId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.classId
        : null;
    }
    // 요청자가 이 반 소유 선생님인가
    function ownsClass(cid) {
      return exists(/databases/$(database)/documents/classes/$(cid))
        && get(/databases/$(database)/documents/classes/$(cid)).data.ownerUid == request.auth.uid;
    }

    // summary 내부 숫자 필드는 숫자만(위조 문자열이 대시보드에 섞이지 않게 서버단 방어)
    function validSummary(s) {
      return (!('streak' in s)     || s.streak is number)
        && (!('accuracy' in s)     || s.accuracy is number)
        && (!('captured' in s)     || s.captured is number)
        && (!('total' in s)        || s.total is number)
        && (!('attempts' in s)     || s.attempts is number)
        && (!('todayCount' in s)   || s.todayCount is number)
        && (!('daily' in s)        || s.daily is map);
    }

    // users/{uid} 쓰기 필드 검증 — 있을 때만 타입/크기 확인.
    function validUserDoc(d) {
      return (!('displayName' in d) || (d.displayName is string && d.displayName.size() <= 40))
        && (!('className' in d)   || (d.className is string && d.className.size() <= 60))
        && (!('classId' in d)     || (d.classId is string && d.classId.size() <= 64))
        && (!('role' in d)        || (d.role is string && (d.role == 'student' || d.role == 'teacher')))
        && (!('profile' in d)     || d.profile is map)
        && (!('summary' in d)     || (d.summary is map && validSummary(d.summary)));
    }

    match /users/{uid} {
      // 본인은 항상, 선생님은 자기 반 학생, 마스터는 전체를 읽을 수 있다.
      allow read: if signedIn() && (request.auth.uid == uid || ownsStudentClass(resource.data) || isMaster());
      // 쓰기는 본인만 + 필드 타입/크기 검증(마스터도 읽기 전용).
      //   ★ role='teacher' 는 teacher 클레임을 가진 사람만 쓸 수 있다(학생 셀프 승격 차단).
      allow write: if signedIn()
        && request.auth.uid == uid
        && validUserDoc(request.resource.data)
        && (!('role' in request.resource.data)
            || request.resource.data.role != 'teacher'
            || teacherAllowed());

      // 무거운 학습 데이터: 본인, 그리고 마스터(전체 열람).
      match /private/{docId} {
        allow read: if signedIn() && (request.auth.uid == uid || isMaster());
        allow write: if signedIn() && request.auth.uid == uid;
      }
    }

    match /classes/{classId} {
      // 소유 선생님(그리고 마스터)만 읽는다(학생은 classCodes 로만 참여, 반 문서를 직접 못 봄 → 열거·PII 차단).
      allow read: if signedIn() && (resource.data.ownerUid == request.auth.uid || isMaster());
      // 생성: 선생님 클레임을 가진 사람만, 자신을 소유자로.
      allow create: if signedIn()
        && teacherAllowed()
        && request.resource.data.ownerUid == request.auth.uid;
      // 수정: 소유자(+선생님 클레임)만 + 소유자·코드·이름 불변, removed 는 배열(제외/복구용 removed 만 바꿀 수 있게).
      allow update: if signedIn()
        && teacherAllowed()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.code == resource.data.code
        && request.resource.data.name == resource.data.name
        && request.resource.data.removed is list;
      // 삭제: 소유자만(선생님 강등·정리 후에도 자기 반은 지울 수 있게 클레임은 요구하지 않음).
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /classCodes/{code} {
      // 코드로 단건 조회만 허용(list 금지 → 전체 코드 열거 불가).
      allow get: if signedIn();
      allow list: if false;
      // 생성 전용 → 이미 있는 코드로는 생성 실패(코드 유일성 보장). update 불가.
      //   선생님 클레임을 가진 사람만(학생이 유령 코드를 심지 못하게).
      allow create: if signedIn()
        && teacherAllowed()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.classId is string;
      allow update: if false;
      // 삭제: 소유자만(반 삭제 시 정리).
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // 반 배포 단어: 선생님이 자기 반에 배포하고, 그 반 학생·소유 선생님·마스터가 읽는다.
    match /classPacks/{cid} {
      allow read: if signedIn() && (
        isMaster()
        || (exists(/databases/$(database)/documents/classes/$(cid))
            && get(/databases/$(database)/documents/classes/$(cid)).data.ownerUid == request.auth.uid)
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.classId == cid)
      );
      // 쓰기: 그 반 소유 "선생님 클레임" 보유자(또는 마스터)만. words 는 배열이어야.
      //   ★ 소유만으로는 불충분 — 선생님 클레임을 요구해 강등된 계정의 배포를 차단.
      allow write: if signedIn()
        && request.resource.data.words is list
        && (
          isMaster()
          || (isTeacher()
              && exists(/databases/$(database)/documents/classes/$(cid))
              && get(/databases/$(database)/documents/classes/$(cid)).data.ownerUid == request.auth.uid)
        );
    }

    // 전체(글로벌) 랭킹: 로그인한 누구나 서로의 표시용 항목(이름·마스터/총 단어수)만 읽고, 각자 자기 것만 쓴다.
    //   경로가 더 구체적이라 아래 반 랭킹 규칙과 OR 로 평가되어, _global 은 이 규칙으로 허용된다.
    match /leaderboards/_global/entries/{uid} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.name is string && request.resource.data.name.size() <= 40
        && request.resource.data.wk is number
        && request.resource.data.streak is number;
      allow delete: if signedIn() && (request.auth.uid == uid || isMaster());
    }

    // 반 주간 랭킹: 같은 반 학생끼리 서로의 항목(이름·주간 단어수·연속)을 읽고, 각자 자기 것만 쓴다.
    //   (이메일·상세 요약은 노출하지 않음 — 표시용 필드만 저장)
    match /leaderboards/{cid}/entries/{uid} {
      allow read: if signedIn() && (requesterClassId() == cid || ownsClass(cid) || isMaster());
      allow write: if signedIn()
        && request.auth.uid == uid
        && requesterClassId() == cid
        && request.resource.data.name is string && request.resource.data.name.size() <= 40
        && request.resource.data.wk is number
        && request.resource.data.streak is number;
      allow delete: if signedIn() && (request.auth.uid == uid || ownsClass(cid) || isMaster());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
